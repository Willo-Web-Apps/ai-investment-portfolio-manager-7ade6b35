---
const year = new Date().getFullYear();
---
<footer style="background: oklch(0.13 0.018 250); border-top: 1px solid oklch(0.95 0.006 80 / 0.06);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">

      <!-- Brand column -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <div class="w-7 h-7 rounded-md flex items-center justify-center" style="background: oklch(0.64 0.16 178);">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" style="color: oklch(0.13 0.018 250);">
              <path d="M12 3L4 9l8 12 8-12-8-6z" fill="currentColor"/>
            </svg>
          </div>
          <span class="text-base font-bold tracking-tight font-display" style="color: oklch(0.95 0.006 80);">Veltora</span>
        </a>
        <p class="text-sm leading-relaxed max-w-xs" style="color: oklch(0.82 0.008 80 / 0.50);">
          Your portfolio's AI advantage. Institutional-grade investment intelligence for self-directed investors.
        </p>
        <p class="mt-4 text-xs" style="color: oklch(0.82 0.008 80 / 0.35);">
          Not a registered investment advisor. AI analysis is for informational purposes only.
        </p>
      </div>

      <!-- Product links -->
      <div>
        <p class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: oklch(0.76 0.13 178);">Product</p>
        <ul class="space-y-2.5">
          <li><a href="#how-it-works" class="text-sm transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.50);"
            onmouseover="this.style.color='oklch(0.95 0.006 80)'"
            onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.50)'"
          >How it works</a></li>
          <li><a href="#cta" class="text-sm transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.50);"
            onmouseover="this.style.color='oklch(0.95 0.006 80)'"
            onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.50)'"
          >Pricing</a></li>
          <li><a href="/blog" class="text-sm transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.50);"
            onmouseover="this.style.color='oklch(0.95 0.006 80)'"
            onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.50)'"
          >Blog</a></li>
          <li><a href="#cta" class="text-sm transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.50);"
            onmouseover="this.style.color='oklch(0.95 0.006 80)'"
            onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.50)'"
          >Security</a></li>
        </ul>
      </div>

      <!-- Company links -->
      <div>
        <p class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: oklch(0.76 0.13 178);">Company</p>
        <ul class="space-y-2.5">
          <li><a href="#" class="text-sm transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.50);"
            onmouseover="this.style.color='oklch(0.95 0.006 80)'"
            onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.50)'"
          >About</a></li>
          <li><a href="mailto:hello@veltora.ai" class="text-sm transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.50);"
            onmouseover="this.style.color='oklch(0.95 0.006 80)'"
            onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.50)'"
          >Contact</a></li>
          <li><a href="#" class="text-sm transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.50);"
            onmouseover="this.style.color='oklch(0.95 0.006 80)'"
            onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.50)'"
          >Privacy</a></li>
          <li><a href="#" class="text-sm transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.50);"
            onmouseover="this.style.color='oklch(0.95 0.006 80)'"
            onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.50)'"
          >Terms</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-3" style="border-top: 1px solid oklch(0.95 0.006 80 / 0.06);">
      <p class="text-sm" style="color: oklch(0.82 0.008 80 / 0.35);">&copy; {year} Veltora. All rights reserved.</p>
      <p class="text-xs" style="color: oklch(0.82 0.008 80 / 0.28);">Your portfolio's AI advantage.</p>
    </div>

  </div>
</footer>
