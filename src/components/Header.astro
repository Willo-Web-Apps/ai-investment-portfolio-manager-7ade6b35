---
---
<header class="sticky top-0 z-50" style="background: oklch(0.13 0.018 250 / 0.85); backdrop-filter: blur(16px); border-bottom: 1px solid oklch(0.95 0.006 80 / 0.06);">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <!-- Teal diamond logo mark -->
      <div class="w-7 h-7 rounded-md flex items-center justify-center flex-shrink-0" style="background: oklch(0.64 0.16 178); box-shadow: 0 0 16px oklch(0.64 0.16 178 / 0.4);">
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" style="color: oklch(0.13 0.018 250);">
          <path d="M12 3L4 9l8 12 8-12-8-6z" fill="currentColor"/>
        </svg>
      </div>
      <span class="text-lg font-bold tracking-tight font-display" style="color: oklch(0.95 0.006 80);">Veltora</span>
    </a>

    <!-- Nav links (desktop) -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#how-it-works" class="text-sm font-medium transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.60);"
        onmouseover="this.style.color='oklch(0.95 0.006 80)'"
        onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.60)'"
      >How it works</a>
      <a href="#cta" class="text-sm font-medium transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.60);"
        onmouseover="this.style.color='oklch(0.95 0.006 80)'"
        onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.60)'"
      >Pricing</a>
      <a href="/blog" class="text-sm font-medium transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.60);"
        onmouseover="this.style.color='oklch(0.95 0.006 80)'"
        onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.60)'"
      >Blog</a>
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a href="#cta" class="hidden sm:block text-sm font-medium transition-colors duration-150" style="color: oklch(0.82 0.008 80 / 0.60);"
        onmouseover="this.style.color='oklch(0.95 0.006 80)'"
        onmouseout="this.style.color='oklch(0.82 0.008 80 / 0.60)'"
      >Sign in</a>
      <a
        href="#cta"
        class="text-sm font-semibold px-4 py-2 rounded-lg transition-all duration-150"
        style="background: oklch(0.64 0.16 178); color: oklch(0.13 0.018 250);"
        onmouseover="this.style.background='oklch(0.54 0.15 178)'"
        onmouseout="this.style.background='oklch(0.64 0.16 178)'"
      >
        Start free
      </a>
    </div>

  </nav>
</header>
