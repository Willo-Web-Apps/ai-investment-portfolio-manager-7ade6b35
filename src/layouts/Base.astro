---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Veltora — Your portfolio's AI advantage",
  description = "Veltora brings institutional-grade AI to self-directed investors — personalized strategies, real-time insights, and full portfolio clarity in one platform."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Veltora",
      "description": "AI-powered investment co-pilot for self-directed investors",
      "url": "https://ai-investment-portfolio-manager.onrender.com",
      "slogan": "Your portfolio's AI advantage"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-body antialiased" style="background: oklch(0.13 0.018 250); color: oklch(0.82 0.008 80);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
